\outl0\strokewidth0 \strokec2 VII \uc0\u3588 \u3623 \u3634 \u3617 \u3605 \u3634 \u3618 \
\
\uc0\u3648 \u3617 \u3639 \u3656 \u3629 \u3605 \u3629 \u3609 \u3618 \u3633 \u3591 \u3648 \u3618 \u3634 \u3623 \u3623 \u3633 \u3618  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3617 \u3636 \u3607 \u3619 \u3634 \u3610 \u3623 \u3656 \u3634 \u3607 \u3640 \u3585 \u3588 \u3609 \u3592 \u3632 \u3605 \u3657 \u3629 \u3591 \u3605 \u3634 \u3618  \u3614 \u3623 \u3585 \u3648 \u3619 \u3634 \u3592 \u3632 \u3617 \u3637 \u3594 \u3637 \u3623 \u3636 \u3605 \u3648 \u3614 \u3639 \u3656 \u3629 \u3648 \u3607 \u3637 \u3656 \u3618 \u3623 \u3648 \u3621 \u3656 \u3609 \u3652 \u3611 \u3605 \u3621 \u3629 \u3604 \u3609 \u3636 \u3619 \u3633 \u3609 \u3604 \u3619 \u3660  \u3585 \u3636 \u3609 \u3586 \u3629 \u3591 \u3629 \u3619 \u3656 \u3629 \u3618 \u3654  \u3649 \u3621 \u3632 \u3651 \u3627 \u3657 \u3649 \u3617 \u3656 \u3585 \u3621 \u3656 \u3629 \u3617 \u3609 \u3629 \u3609 \u3607 \u3640 \u3585 \u3588 \u3639 \u3609 \
\
\uc0\u3629 \u3634 \u3592 \u3592 \u3632 \u3648 \u3611 \u3655 \u3609 \u3648 \u3614 \u3619 \u3634 \u3632 \u3586 \u3656 \u3634 \u3623 \u3626 \u3634 \u3619  \u3648 \u3627 \u3655 \u3609 \u3588 \u3609 \u3649 \u3585 \u3656  \u3588 \u3609 \u3605 \u3634 \u3618  \u3604 \u3657 \u3623 \u3618 \u3648 \u3627 \u3605 \u3640 \u3651 \u3604 \u3617 \u3636 \u3607 \u3619 \u3634 \u3610 \u3652 \u3604 \u3657  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3606 \u3634 \u3617 \u3649 \u3617 \u3656 \u3623 \u3656 \u3634  \u3588 \u3609 \u3648 \u3619 \u3634 \u3605 \u3657 \u3629 \u3591 \u3605 \u3634 \u3618 \u3592 \u3619 \u3636 \u3591 \u3654 \u3627 \u3619 \u3639 \u3629  \u3588 \u3635 \u3605 \u3629 \u3610 \u3585 \u3655 \u3588 \u3639 \u3629 \u3651 \u3594 \u3656  \u3585 \u3634 \u3619 \u3619 \u3633 \u3610 \u3619 \u3641 \u3657 \u3626 \u3636 \u3656 \u3591 \u3609 \u3637 \u3657 \u3607 \u3635 \u3651 \u3627 \u3657 \u3648 \u3604 \u3655 \u3585  5-6 \u3586 \u3623 \u3610 \u3611 \u3637  \u3594 \u3632 \u3591 \u3633 \u3585 \u3652 \u3611 \u3626 \u3633 \u3585 \u3588 \u3619 \u3641 \u3656  \u3649 \u3605 \u3656 \u3649 \u3621 \u3657 \u3623 \u3585 \u3655 \u3621 \u3639 \u3617 \u3652 \u3611 \u3605 \u3634 \u3617 \u3611 \u3619 \u3632 \u3626 \u3634 \u3648 \u3604 \u3655 \u3585 \
\
\uc0\u3648 \u3617 \u3639 \u3656 \u3629 \u3648 \u3605 \u3636 \u3610 \u3650 \u3605 \u3586 \u3638 \u3657 \u3609 \u3617 \u3634 \u3588 \u3623 \u3634 \u3617 \u3592 \u3619 \u3636 \u3591 \u3623 \u3633 \u3609 \u3609 \u3633 \u3657 \u3609 \u3585 \u3655 \u3618 \u3636 \u3656 \u3591 \u3592 \u3619 \u3636 \u3591 \u3617 \u3634 \u3585 \u3618 \u3636 \u3656 \u3591 \u3586 \u3638 \u3657 \u3609 \u3648 \u3617 \u3639 \u3656 \u3629 \u3648 \u3627 \u3655 \u3609 \u3588 \u3609 \u3651 \u3585 \u3621 \u3657 \u3605 \u3633 \u3623  \u3588 \u3609 \u3607 \u3637 \u3656 \u3648 \u3619 \u3634 \u3619 \u3633 \u3585  \u3627 \u3619 \u3639 \u3629 \u3648 \u3614 \u3639 \u3656 \u3629 \u3609 \u3613 \u3641 \u3591  \u3592 \u3634 \u3585 \u3652 \u3611 \u3585 \u3633 \u3609 \u3607 \u3637 \u3621 \u3632 \u3588 \u3609  \u3618 \u3636 \u3656 \u3591 \u3617 \u3637 \u3650 \u3595 \u3648 \u3594 \u3637 \u3618 \u3621 \u3617 \u3637 \u3648 \u3604 \u3637 \u3618  \u3586 \u3656 \u3634 \u3623 \u3626 \u3634 \u3619 \u3585 \u3655 \u3618 \u3636 \u3656 \u3591 \u3619 \u3623 \u3604 \u3648 \u3619 \u3655 \u3623  \u3593 \u3633 \u3610 \u3652 \u3623  \u3607 \u3635 \u3652 \u3617 \u3651 \u3627 \u3657 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3605 \u3657 \u3629 \u3591 \u3617 \u3634 \u3605 \u3619 \u3632 \u3627 \u3609 \u3633 \u3585 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3588 \u3623 \u3634 \u3617 \u3605 \u3634 \u3618 \u3629 \u3637 \u3585 \u3607 \u3637 \
\
\uc0\u3651 \u3609 \u3588 \u3623 \u3634 \u3617 \u3588 \u3636 \u3604 \u3586 \u3629 \u3591 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634  \u3648 \u3619 \u3636 \u3656 \u3617 \u3649 \u3619 \u3585 \u3648 \u3604 \u3636 \u3617 \u3607 \u3637 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3588 \u3636 \u3604 \u3623 \u3656 \u3634 \u3588 \u3623 \u3634 \u3617 \u3605 \u3634 \u3618 \u3609 \u3633 \u3657 \u3609 \u3609 \u3656 \u3634 \u3585 \u3621 \u3633 \u3623  \u3588 \u3591 \u3648 \u3605 \u3655 \u3617 \u3652 \u3611 \u3604 \u3657 \u3623 \u3618 \u3588 \u3623 \u3634 \u3617 \u3617 \u3639 \u3604 \u3617 \u3636 \u3604  \u3588 \u3623 \u3634 \u3617 \u3623 \u3656 \u3634 \u3591 \u3648 \u3611 \u3621 \u3656 \u3634  \u3648 \u3619 \u3634 \u3592 \u3632 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3614 \u3610 \u3651 \u3588 \u3619 \u3629 \u3637 \u3585 \u3605 \u3656 \u3629 \u3652 \u3611  \u3649 \u3617 \u3657 \u3649 \u3605 \u3656 \u3605 \u3633 \u3623 \u3648 \u3629 \u3591  \u3609 \u3633 \u3656 \u3609 \u3588 \u3639 \u3629 \u3588 \u3623 \u3634 \u3617 \u3650 \u3604 \u3604 \u3648 \u3604 \u3637 \u3656 \u3618 \u3623 \u3649 \u3610 \u3610 \u3648 \u3604 \u3637 \u3618 \u3623 \u3604 \u3634 \u3618  \u3614 \u3629 \u3648 \u3629 \u3634 \u3648 \u3586 \u3657 \u3634 \u3592 \u3619 \u3636 \u3591 \u3648 \u3619 \u3634 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3649 \u3611 \u3619 \u3626 \u3634 \u3619 \u3609 \u3637 \u3657 \u3651 \u3627 \u3657 \u3648 \u3611 \u3655 \u3609  \'93\u3588 \u3623 \u3634 \u3617 \u3626 \u3591 \u3610 \u3626 \u3640 \u3586 \'94 , \'93\u3626 \u3633 \u3609 \u3605 \u3636 \u3626 \u3640 \u3586 \'94, \'93\u3585 \u3634 \u3619 \u3614 \u3633 \u3585 \u3612 \u3656 \u3629 \u3609 \'94 \u3652 \u3604 \u3657  \u3604 \u3633 \u3591 \u3609 \u3633 \u3657 \u3609 \u3588 \u3623 \u3634 \u3617 \u3627 \u3623 \u3634 \u3604 \u3585 \u3621 \u3633 \u3623 \u3586 \u3629 \u3591 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3605 \u3656 \u3629 \u3588 \u3623 \u3634 \u3617 \u3605 \u3634 \u3618 \u3609 \u3633 \u3657 \u3609 \u3588 \u3656 \u3629 \u3618 \u3654 \u3606 \u3641 \u3585 \u3649 \u3611 \u3619 \u3648 \u3611 \u3621 \u3637 \u3656 \u3618 \u3609 \u3607 \u3637 \u3621 \u3632 \u3609 \u3636 \u3604 \
\
\uc0\u3649 \u3605 \u3656 \u3617 \u3633 \u3609 \u3617 \u3637 \u3626 \u3636 \u3656 \u3591 \u3627 \u3609 \u3638 \u3656 \u3591 \u3607 \u3637 \u3656 \u3609 \u3656 \u3634 \u3585 \u3621 \u3633 \u3623 \u3585 \u3623 \u3656 \u3634  \u3588 \u3639 \u3629  \u3648 \u3623 \u3621 \u3634 \u3585 \u3656 \u3629 \u3609 \u3605 \u3634 \u3618 ,\u3626 \u3636 \u3656 \u3591 \u3609 \u3637 \u3657 \u3588 \u3639 \u3629 \u3586 \u3629 \u3591 \u3592 \u3619 \u3636 \u3591  \u3588 \u3640 \u3603 \u3618 \u3633 \u3591 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3626 \u3633 \u3617 \u3612 \u3633 \u3626 \u3619 \u3633 \u3610 \u3619 \u3641 \u3657 \u3652 \u3604 \u3657 \u3649 \u3610 \u3610 \u3648 \u3605 \u3655 \u3617 \u3654  \u3607 \u3633 \u3657 \u3591 \u3651 \u3609 \u3604 \u3657 \u3634 \u3609 \u3585 \u3634 \u3618 \u3616 \u3634 \u3614 \u3649 \u3621 \u3632 \u3607 \u3634 \u3591 \u3592 \u3636 \u3605 \u3651 \u3592  \u3626 \u3636 \u3656 \u3591 \u3609 \u3637 \u3657 \u3626 \u3656 \u3591 \u3612 \u3621 \u3605 \u3656 \u3629 \u3588 \u3609 \u3619 \u3629 \u3610 \u3586 \u3657 \u3634 \u3591 \u3604 \u3657 \u3623 \u3618  \u3617 \u3636 \u3651 \u3594 \u3656 \u3612 \u3641 \u3657 \u3607 \u3637 \u3656 \u3592 \u3632 \u3605 \u3634 \u3618 \u3648 \u3614 \u3637 \u3618 \u3591 \u3588 \u3609 \u3648 \u3604 \u3637 \u3618 \u3623  \u3604 \u3633 \u3591 \u3609 \u3633 \u3657 \u3609 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3592 \u3638 \u3591 \u3614 \u3618 \u3634 \u3618 \u3634 \u3617 \u3624 \u3638 \u3585 \u3625 \u3634 \u3651 \u3609 \u3585 \u3634 \u3619 \u3607 \u3637 \u3656 \u3592 \u3632 \u3619 \u3633 \u3610 \u3617 \u3639 \u3629 \u3585 \u3633 \u3610 \u3648 \u3627 \u3605 \u3640 \u3585 \u3634 \u3619 \u3603 \u3660 \u3609 \u3637 \u3657  \u3595 \u3638 \u3656 \u3591 \u3648 \u3619 \u3634 \u3607 \u3640 \u3585 \u3588 \u3609 \u3617 \u3636 \u3629 \u3634 \u3592 \u3627 \u3621 \u3637 \u3585 \u3648 \u3621 \u3637 \u3656 \u3618 \u3591 \u3652 \u3604 \u3657 \
\
\uc0\u3651 \u3609 \u3588 \u3623 \u3634 \u3617 \u3588 \u3636 \u3604 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634  \u3588 \u3609 \u3607 \u3637 \u3656 \u3585 \u3635 \u3621 \u3633 \u3591 \u3592 \u3632 \u3605 \u3634 \u3618  \u3652 \u3617 \u3656 \u3623 \u3656 \u3634 \u3592 \u3632 \u3604 \u3657 \u3623 \u3618 \u3629 \u3640 \u3610 \u3633 \u3605 \u3636 \u3648 \u3627 \u3605 \u3640 \u3610 \u3609 \u3606 \u3609 \u3609 , \u3610 \u3609 \u3648 \u3605 \u3637 \u3618 \u3591 \u3651 \u3609 \u3650 \u3619 \u3591 \u3614 \u3618 \u3634 \u3610 \u3634 \u3621 , \u3627 \u3619 \u3639 \u3629 \u3649 \u3617 \u3657 \u3649 \u3605 \u3656 \u3588 \u3609 \u3607 \u3637 \u3656 \u3592 \u3632 \u3606 \u3641 \u3585 \u3590 \u3634 \u3605 \u3585 \u3619 \u3619 \u3617  \u3629 \u3634 \u3619 \u3617 \u3603 \u3660 \u3614 \u3623 \u3585 \u3648 \u3586 \u3634 \u3588 \u3591 \u3592 \u3632 \u3648 \u3605 \u3655 \u3617 \u3652 \u3611 \u3604 \u3657 \u3623 \u3618 \u3588 \u3623 \u3634 \u3617 \u3585 \u3621 \u3633 \u3623 , \u3588 \u3623 \u3634 \u3617 \u3648 \u3624 \u3619 \u3657 \u3634 \u3627 \u3617 \u3629 \u3591  \u3627 \u3634 \u3585 \u3648 \u3611 \u3655 \u3609 \u3648 \u3619 \u3634  \u3648 \u3619 \u3634 \u3592 \u3632 \u3607 \u3635 \u3629 \u3618 \u3656 \u3634 \u3591 \u3652 \u3619 \u3604 \u3637 \
\
\uc0\u3627 \u3634 \u3585 \u3648 \u3621 \u3639 \u3629 \u3585 \u3652 \u3604 \u3657 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3586 \u3629 \u3586 \u3657 \u3634 \u3617 \u3586 \u3633 \u3657 \u3609 \u3605 \u3629 \u3609 \u3609 \u3637 \u3657 \u3652 \u3611 \u3648 \u3619 \u3655 \u3623 \u3618 \u3633 \u3591 \u3592 \u3632 \u3604 \u3637 \u3648 \u3626 \u3637 \u3618 \u3585 \u3623 \u3656 \u3634  \u3649 \u3605 \u3656 \u3651 \u3609 \u3648 \u3617 \u3639 \u3656 \u3629 \u3648 \u3621 \u3639 \u3629 \u3585 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3585 \u3655 \u3588 \u3591 \u3605 \u3657 \u3629 \u3591 \u3618 \u3629 \u3617 \u3619 \u3633 \u3610 \u3649 \u3621 \u3632 \u3627 \u3634 \u3623 \u3636 \u3608 \u3637 \u3619 \u3633 \u3610 \u3617 \u3639 \u3629  \u3617 \u3637 \u3627 \u3621 \u3634 \u3618 \u3624 \u3634 \u3626 \u3609 \u3634 \u3627 \u3621 \u3634 \u3585 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629  \u3629 \u3657 \u3634 \u3591 \u3648 \u3611 \u3655 \u3609 \u3605 \u3633 \u3623 \u3649 \u3607 \u3609 \u3594 \u3656 \u3623 \u3618 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3609 \u3637 \u3657 \u3652 \u3604 \u3657  \u3651 \u3609 \u3624 \u3634 \u3626 \u3609 \u3634 \u3605 \u3632 \u3623 \u3633 \u3609 \u3629 \u3629 \u3585 \u3626 \u3656 \u3623 \u3609 \u3651 \u3627 \u3597 \u3656 \u3617 \u3633 \u3585 \u3592 \u3632 \u3651 \u3627 \u3657 \u3588 \u3640 \u3603 \u3588 \u3656 \u3634 \u3586 \u3629 \u3591 \u3588 \u3635 \u3623 \u3656 \u3634  \'93\u3592 \u3636 \u3605 \u3626 \u3640 \u3604 \u3607 \u3657 \u3634 \u3618 \'94 \u3588 \u3639 \u3629 \u3629 \u3634 \u3619 \u3617 \u3603 \u3660 \u3626 \u3640 \u3604 \u3607 \u3657 \u3634 \u3618 \u3586 \u3629 \u3591 \u3612 \u3641 \u3657 \u3592 \u3632 \u3605 \u3634 \u3618 \u3592 \u3632 \u3626 \u3656 \u3591 \u3612 \u3621 \u3605 \u3656 \u3629 \u3616 \u3614 \u3616 \u3641 \u3617 \u3636 \u3627 \u3609 \u3657 \u3634  \u3604 \u3633 \u3591 \u3609 \u3633 \u3657 \u3609  \u3648 \u3619 \u3634 \u3605 \u3657 \u3629 \u3591 \u3648 \u3610 \u3636 \u3585 \u3610 \u3634 \u3609 \u3585 \u3656 \u3629 \u3609 \u3605 \u3634 \u3618  \u3621 \u3632 \u3595 \u3638 \u3656 \u3591 \u3629 \u3634 \u3619 \u3617 \u3603 \u3660 \u3604 \u3657 \u3634 \u3609 \u3621 \u3610  \u3649 \u3605 \u3656 \u3588 \u3609 \u3592 \u3632 \u3605 \u3634 \u3618 \u3649 \u3621 \u3657 \u3623  \u3651 \u3588 \u3619 \u3617 \u3633 \u3609 \u3592 \u3632 \u3607 \u3635 \u3652 \u3604 \u3657  \u3604 \u3633 \u3591 \u3609 \u3633 \u3657 \u3609 \u3648 \u3619 \u3634 \u3592 \u3638 \u3591 \u3605 \u3657 \u3629 \u3591 \u3617 \u3637 \u3585 \u3634 \u3619 \u3613 \u3638 \u3585 \u3595 \u3657 \u3629 \u3617 \u3585 \u3633 \u3610 \u3585 \u3634 \u3619 \u3648 \u3604 \u3636 \u3609 \u3607 \u3634 \u3591 \u3588 \u3619 \u3633 \u3657 \u3591 \u3609 \u3637 \u3657 \
\
\uc0\u3651 \u3609 \u3585 \u3634 \u3619 \u3648 \u3605 \u3619 \u3637 \u3618 \u3617 \u3605 \u3633 \u3623 \u3605 \u3634 \u3618  \u3627 \u3619 \u3639 \u3629 \u3619 \u3641 \u3657 \u3623 \u3656 \u3634 \u3592 \u3632 \u3605 \u3634 \u3618 \u3609 \u3633 \u3657 \u3609  \u3585 \u3634 \u3619 \u3651 \u3594 \u3657 \u3624 \u3634 \u3626 \u3609 \u3634 \u3649 \u3621 \u3632 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \u3617 \u3634 \u3648 \u3611 \u3655 \u3609 \u3648 \u3588 \u3619 \u3639 \u3656 \u3629 \u3591 \u3617 \u3639 \u3629 \u3592 \u3632 \u3626 \u3656 \u3591 \u3612 \u3621 \u3652 \u3604 \u3657 \u3629 \u3618 \u3656 \u3634 \u3591 \u3617 \u3634 \u3585  \u3651 \u3609 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591  \'93\u3618 \u3638 \u3604 \u3648 \u3627 \u3609 \u3637 \u3656 \u3618 \u3623 \u3592 \u3636 \u3605 \u3651 \u3592 \'94 \u3649 \u3609 \u3656 \u3609 \u3629 \u3609 \u3623 \u3656 \u3634 \u3617 \u3633 \u3609 \u3614 \u3636 \u3626 \u3641 \u3592 \u3609 \u3660 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3651 \u3609 \u3607 \u3634 \u3591 \u3623 \u3636 \u3607 \u3618 \u3634 \u3624 \u3634 \u3626 \u3605 \u3619 \u3660  \u3649 \u3605 \u3656 \u3617 \u3633 \u3609 \u3648 \u3627 \u3655 \u3609 \u3612 \u3621 \u3651 \u3609 \u3604 \u3657 \u3634 \u3609 \u3592 \u3636 \u3605 \u3624 \u3634 \u3626 \u3605 \u3619 \u3660  \u3648 \u3619 \u3634 \u3648 \u3627 \u3655 \u3609 \u3588 \u3609 \u3627 \u3621 \u3634 \u3618 \u3588 \u3609 \u3607 \u3637 \u3656 \u3585 \u3657 \u3634 \u3623 \u3612 \u3656 \u3634 \u3609 \u3588 \u3623 \u3634 \u3617 \u3605 \u3634 \u3618 \u3617 \u3634 \u3652 \u3604 \u3657 \u3609 \u3633 \u3657 \u3609  \u3617 \u3633 \u3585 \u3592 \u3632 \u3617 \u3637 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \u3610 \u3634 \u3591 \u3629 \u3618 \u3656 \u3634 \u3591 \u3648 \u3586 \u3657 \u3634 \u3617 \u3634 \u3651 \u3609 \u3594 \u3637 \u3623 \u3636 \u3605  \u3649 \u3617 \u3657 \u3592 \u3632 \u3652 \u3617 \u3656 \u3651 \u3594 \u3656 \u3607 \u3640 \u3585 \u3588 \u3609 \u3585 \u3655 \u3605 \u3634 \u3617 \
\
\uc0\u3649 \u3621 \u3657 \u3623 \u3606 \u3657 \u3634 \u3648 \u3619 \u3634 \u3610 \u3629 \u3585 \u3623 \u3656 \u3634  \u3648 \u3604 \u3637 \u3659 \u3618 \u3623 \u3588 \u3656 \u3629 \u3618 \u3648 \u3594 \u3639 \u3656 \u3629 \u3627 \u3619 \u3639 \u3629 \u3648 \u3621 \u3639 \u3629 \u3585 \u3609 \u3633 \u3610 \u3606 \u3639 \u3629 \u3624 \u3634 \u3626 \u3609 \u3634 \u3609 \u3633 \u3657 \u3609 \u3654 \u3605 \u3629 \u3609 \u3651 \u3585 \u3621 \u3657 \u3592 \u3632 \u3605 \u3634 \u3618 \u3649 \u3621 \u3657 \u3623 \u3585 \u3633 \u3609  \u3648 \u3623 \u3621 \u3634 \u3609 \u3637 \u3657 \u3586 \u3629 \u3651 \u3594 \u3657 \u3594 \u3637 \u3623 \u3636 \u3605 \u3605 \u3656 \u3629 \u3652 \u3611 \u3649 \u3610 \u3610 \u3609 \u3637 \u3657 \u3585 \u3656 \u3629 \u3609  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3648 \u3588 \u3618 \u3617 \u3637 \u3588 \u3623 \u3634 \u3617 \u3588 \u3636 \u3604 \u3649 \u3610 \u3610 \u3609 \u3637 \u3657  \u3649 \u3605 \u3656 \u3648 \u3617 \u3639 \u3656 \u3629 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3626 \u3633 \u3617 \u3612 \u3633 \u3626 \u3611 \u3619 \u3632 \u3626 \u3610 \u3585 \u3634 \u3619 \u3603 \u3660 \u3651 \u3585 \u3621 \u3657 \u3605 \u3634 \u3618 \u3627 \u3619 \u3639 \u3629  \u3588 \u3636 \u3604 \u3652 \u3611 \u3648 \u3629 \u3591 \u3623 \u3656 \u3634 \u3605 \u3633 \u3623 \u3648 \u3629 \u3591 \u3585 \u3635 \u3621 \u3633 \u3591 \u3592 \u3632 \u3605 \u3634 \u3618  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3623 \u3656 \u3634 \u3626 \u3605 \u3636 \u3649 \u3605 \u3585 \u3585 \u3619 \u3632 \u3648 \u3592 \u3636 \u3591 \u3648 \u3605 \u3655 \u3617 \u3652 \u3611 \u3604 \u3657 \u3623 \u3618 \u3588 \u3623 \u3634 \u3617 \u3627 \u3623 \u3634 \u3604 \u3585 \u3621 \u3633 \u3623  \u3648 \u3619 \u3634 \u3652 \u3617 \u3656 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3648 \u3621 \u3639 \u3629 \u3585 \u3607 \u3637 \u3656 \u3592 \u3632 \u3648 \u3594 \u3639 \u3656 \u3629 \u3627 \u3619 \u3639 \u3629 \u3652 \u3617 \u3656 \u3648 \u3594 \u3639 \u3656 \u3629 \u3629 \u3632 \u3652 \u3619 \u3652 \u3604 \u3657 \u3629 \u3637 \u3585 \u3605 \u3656 \u3629 \u3652 \u3611  \u3626 \u3617 \u3629 \u3591 \u3617 \u3633 \u3609 \u3619 \u3623 \u3609  \u3591 \u3640 \u3609 \u3591 \u3591  \u3607 \u3635 \u3591 \u3634 \u3609 \u3652 \u3604 \u3657 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657  \u3604 \u3633 \u3591 \u3609 \u3633 \u3657 \u3609 \u3626 \u3636 \u3656 \u3591 \u3607 \u3637 \u3656 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3592 \u3632 \u3648 \u3626 \u3609 \u3629 \u3585 \u3655 \u3588 \u3639 \u3629  \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 , \u3624 \u3634 \u3626 \u3609 \u3634 , \u3611 \u3634 \u3599 \u3636 \u3627 \u3634 \u3619 \u3618 \u3660 ,\u3585 \u3599 \u3649 \u3627 \u3656 \u3591 \u3585 \u3619 \u3619 \u3617 , \u3626 \u3633 \u3591 \u3626 \u3634 \u3619 \u3623 \u3633 \u3599 , \u3614 \u3619 \u3632 \u3648 \u3592 \u3657 \u3634  \u3609 \u3633 \u3657 \u3609 \u3651 \u3594 \u3657 \u3648 \u3623 \u3621 \u3634 \u3585 \u3623 \u3656 \u3634 \u3617 \u3633 \u3609 \u3592 \u3632 \u3612 \u3621 \u3636 \u3604 \u3629 \u3585 \u3629 \u3629 \u3585 \u3612 \u3621 \
\
\uc0\u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3648 \u3621 \u3618 \u3648 \u3621 \u3639 \u3629 \u3585 \u3607 \u3637 \u3656 \u3592 \u3632 \u3585 \u3621 \u3634 \u3618 \u3648 \u3611 \u3655 \u3609  \'93\u3612 \u3641 \u3657 \u3607 \u3637 \u3656 \u3617 \u3637 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \'94 \u3648 \u3585 \u3637 \u3656 \u3618 \u3623 \u3585 \u3633 \u3610 \u3624 \u3634 \u3626 \u3609 \u3634  \u3648 \u3627 \u3605 \u3640 \u3648 \u3614 \u3619 \u3634 \u3632 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3629 \u3656 \u3629 \u3609 \u3649 \u3629 \u3649 \u3621 \u3632 \u3627 \u3623 \u3634 \u3604 \u3585 \u3621 \u3633 \u3623 \u3648 \u3585 \u3636 \u3609 \u3652 \u3611 \u3607 \u3637 \u3656 \u3592 \u3632 \u3592 \u3634 \u3585 \u3650 \u3621 \u3585 \u3609 \u3637 \u3657 \u3652 \u3611 \u3648 \u3614 \u3637 \u3618 \u3591 \u3621 \u3635 \u3614 \u3633 \u3591 \u3650 \u3604 \u3618 \u3652 \u3617 \u3656 \u3617 \u3637 \u3629 \u3632 \u3652 \u3619 \u3618 \u3638 \u3604 \u3648 \u3627 \u3609 \u3637 \u3656 \u3618 \u3623  \u3607 \u3633 \u3657 \u3591 \u3654 \u3605 \u3629 \u3609 \u3649 \u3619 \u3585 \u3609 \u3633 \u3657 \u3609  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3588 \u3636 \u3604 \u3623 \u3656 \u3634 \u3605 \u3609 \u3648 \u3629 \u3591 \u3648 \u3585 \u3656 \u3591 \u3585 \u3634 \u3592  \u3617 \u3636 \u3629 \u3634 \u3592 \u3617 \u3637 \u3626 \u3636 \u3656 \u3591 \u3651 \u3604 \u3607 \u3637 \u3656 \u3592 \u3632 \u3607 \u3635 \u3651 \u3592 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3652 \u3627 \u3623 \u3627 \u3623 \u3633 \u3656 \u3609 \u3652 \u3604 \u3657  \u3615 \u3633 \u3591 \u3604 \u3641 \u3648 \u3627 \u3617 \u3639 \u3629 \u3609  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3648 \u3611 \u3655 \u3609 \u3588 \u3609 \u3627 \u3609 \u3657 \u3634 \u3595 \u3639 \u3656 \u3629 \u3651 \u3592 \u3588 \u3604  \u3611 \u3634 \u3585 \u3610 \u3629 \u3585 \u3648 \u3594 \u3639 \u3656 \u3629  \u3649 \u3605 \u3656 \u3585 \u3655 \u3648 \u3594 \u3639 \u3656 \u3629 \u3652 \u3611 \u3648 \u3614 \u3619 \u3634 \u3632 \u3649 \u3610 \u3610 \u3609 \u3633 \u3657 \u3609  \u3649 \u3610 \u3610 \u3609 \u3637 \u3657  \u3614 \u3629 \u3592 \u3632 \u3605 \u3634 \u3618 \u3592 \u3619 \u3636 \u3591 \u3654 \u3588 \u3591 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3594 \u3656 \u3623 \u3618 \u3629 \u3632 \u3652 \u3619 \u3617 \u3634 \u3585  \u3648 \u3614 \u3619 \u3634 \u3632 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3648 \u3594 \u3639 \u3656 \u3629 \u3592 \u3619 \u3636 \u3591 \u3654 \
\
\uc0\u3649 \u3609 \u3656 \u3609 \u3629 \u3609 \u3623 \u3656 \u3634 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3585 \u3655 \u3605 \u3633 \u3657 \u3591 \u3588 \u3635 \u3606 \u3634 \u3617 \u3648 \u3594 \u3656 \u3609 \u3609 \u3637 \u3657 \u3585 \u3633 \u3610 \u3605 \u3609 \u3648 \u3629 \u3591 \u3648 \u3594 \u3656 \u3609 \u3585 \u3633 \u3609  \u3623 \u3656 \u3634 \u3585 \u3634 \u3619 \u3607 \u3637 \u3656 \u3592 \u3632 \u3595 \u3639 \u3657 \u3629 \u3652 \u3629 \u3648 \u3604 \u3637 \u3618 \u3651 \u3609 \u3627 \u3621 \u3633 \u3585 \u3585 \u3634 \u3619 \u3586 \u3629 \u3591 \u3624 \u3634 \u3626 \u3609 \u3634 \u3627 \u3619 \u3639 \u3629 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \u3651 \u3604 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \u3627 \u3609 \u3638 \u3656 \u3591 \u3609 \u3633 \u3657 \u3609  \u3617 \u3633 \u3609 \u3605 \u3657 \u3629 \u3591 \u3648 \u3594 \u3639 \u3656 \u3629 \u3592 \u3619 \u3636 \u3591 \u3654 \u3606 \u3638 \u3591 \u3592 \u3632 \u3626 \u3633 \u3617 \u3620 \u3636 \u3607 \u3608 \u3636 \u3660 \u3612 \u3621 \u3651 \u3609 \u3592 \u3636 \u3605 \u3651 \u3592  \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3609 \u3637 \u3657 \u3617 \u3633 \u3609 \u3648 \u3611 \u3655 \u3609 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3621 \u3632 \u3648 \u3629 \u3637 \u3618 \u3604 \u3629 \u3656 \u3629 \u3609  \u3618 \u3636 \u3656 \u3591 \u3651 \u3609 \u3618 \u3640 \u3588 \u3607 \u3637 \u3656 \u3626 \u3633 \u3591 \u3588 \u3617 \u3618 \u3638 \u3604 \u3606 \u3639 \u3629 \u3588 \u3640 \u3603 \u3588 \u3656 \u3634 \u3607 \u3634 \u3591 \u3623 \u3636 \u3607 \u3618 \u3634 \u3624 \u3634 \u3626 \u3605 \u3619 \u3660 \u3648 \u3611 \u3655 \u3609 \u3627 \u3621 \u3633 \u3585  \u3614 \u3623 \u3585 \u3648 \u3619 \u3634 \u3617 \u3633 \u3585 \u3592 \u3632 \u3651 \u3594 \u3657 \u3627 \u3621 \u3633 \u3585 \u3648 \u3627 \u3605 \u3640 \u3612 \u3621 \u3609 \u3635  \u3605 \u3657 \u3629 \u3591 \u3614 \u3636 \u3626 \u3641 \u3592 \u3609 \u3660 \u3652 \u3604 \u3657 \u3605 \u3634 \u3617 \u3627 \u3621 \u3633 \u3585 \u3585 \u3634 \u3619 \u3623 \u3636 \u3607 \u3618 \u3634 \u3624 \u3634 \u3626 \u3605 \u3619 \u3660  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3585 \u3655 \u3648 \u3611 \u3655 \u3609 \u3627 \u3609 \u3638 \u3656 \u3591 \u3651 \u3609 \u3609 \u3633 \u3657 \u3609  \u3604 \u3657 \u3623 \u3618 \u3627 \u3621 \u3633 \u3585 \u3624 \u3634 \u3626 \u3609 \u3634 \u3617 \u3633 \u3585 \u3592 \u3632 \u3617 \u3637 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3611 \u3634 \u3599 \u3636 \u3627 \u3634 \u3619 \u3618 \u3660 \u3629 \u3618 \u3641 \u3656 \u3648 \u3626 \u3617 \u3629  \u3592 \u3638 \u3591 \u3617 \u3633 \u3585 \u3592 \u3632 \u3586 \u3633 \u3604 \u3649 \u3618 \u3657 \u3591 \u3585 \u3633 \u3610 \u3588 \u3640 \u3603 \u3588 \u3656 \u3634 \u3605 \u3619 \u3591 \u3609 \u3637 \u3657 \
\
\uc0\u3649 \u3605 \u3656 \u3648 \u3619 \u3634 \u3617 \u3633 \u3585 \u3621 \u3639 \u3617 \u3652 \u3611 \u3623 \u3656 \u3634 \u3626 \u3636 \u3656 \u3591 \u3648 \u3627 \u3621 \u3656 \u3634 \u3609 \u3637 \u3657 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3651 \u3594 \u3657 \u3626 \u3617 \u3629 \u3591 \u3648 \u3594 \u3639 \u3656 \u3629  \u3649 \u3605 \u3656 \u3617 \u3633 \u3609 \u3651 \u3594 \u3657 \u3627 \u3633 \u3623 \u3651 \u3592 \u3651 \u3609 \u3585 \u3634 \u3619 \u3648 \u3594 \u3639 \u3656 \u3629  \u3648 \u3619 \u3634 \u3652 \u3617 \u3656 \u3592 \u3635 \u3648 \u3611 \u3655 \u3609 \u3605 \u3657 \u3629 \u3591 \u3614 \u3636 \u3626 \u3641 \u3592 \u3609 \u3660 \u3617 \u3633 \u3609 \u3607 \u3640 \u3585 \u3629 \u3618 \u3656 \u3634 \u3591  \u3652 \u3617 \u3656 \u3605 \u3657 \u3629 \u3591 \u3607 \u3604 \u3621 \u3629 \u3591 \u3649 \u3621 \u3657 \u3623 \u3612 \u3621 \u3621 \u3633 \u3614 \u3608 \u3660 \u3605 \u3619 \u3591 \u3605 \u3634 \u3617 \u3648 \u3604 \u3636 \u3617 \u3607 \u3640 \u3585 \u3588 \u3619 \u3633 \u3657 \u3591  \u3617 \u3633 \u3609 \u3652 \u3617 \u3656 \u3651 \u3594 \u3656 \u3588 \u3603 \u3636 \u3605 \u3624 \u3634 \u3626 \u3605 \u3619 \u3660  \u3649 \u3605 \u3656 \u3617 \u3633 \u3609 \u3648 \u3611 \u3655 \u3609 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3607 \u3637 \u3656 \u3621 \u3638 \u3585 \u3595 \u3638 \u3657 \u3591 \u3585 \u3623 \u3656 \u3634 \u3609 \u3633 \u3657 \u3609 \u3617 \u3634 \u3585  \u3604 \u3633 \u3591 \u3609 \u3633 \u3657 \u3609 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3592 \u3638 \u3591 \u3624 \u3638 \u3585 \u3625 \u3634 \u3649 \u3621 \u3632 \u3648 \u3611 \u3636 \u3604 \u3651 \u3592 \u3651 \u3627 \u3657 \u3585 \u3633 \u3610 \u3614 \u3639 \u3657 \u3609 \u3607 \u3637 \u3656 \u3605 \u3619 \u3591 \u3609 \u3637 \u3657 \
\
\uc0\u3611 \u3619 \u3634 \u3585 \u3599 \u3623 \u3656 \u3634 \u3617 \u3633 \u3609 \u3585 \u3655 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3648 \u3621 \u3623 \u3619 \u3657 \u3634 \u3618 \u3586 \u3609 \u3634 \u3604 \u3609 \u3633 \u3657 \u3609 \u3648 \u3617 \u3639 \u3656 \u3629 \u3648 \u3619 \u3634 \u3651 \u3594 \u3657 \u3651 \u3592 \u3648 \u3594 \u3639 \u3656 \u3629  \u3652 \u3617 \u3656 \u3651 \u3594 \u3657 \u3626 \u3617 \u3629 \u3591 \u3648 \u3594 \u3639 \u3656 \u3629  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3614 \u3610 \u3585 \u3633 \u3610 \u3626 \u3636 \u3656 \u3591 \u3617 \u3627 \u3633 \u3626 \u3592 \u3619 \u3619 \u3618 \u3660 \u3617 \u3634 \u3585 \u3617 \u3634 \u3618 \u3648 \u3585 \u3636 \u3609 \u3585 \u3623 \u3656 \u3634 \u3607 \u3637 \u3656 \u3626 \u3617 \u3629 \u3591 \u3648 \u3619 \u3634 \u3619 \u3633 \u3610 \u3619 \u3641 \u3657  \u3610 \u3634 \u3591 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3648 \u3611 \u3655 \u3609 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3607 \u3637 \u3656 \u3648 \u3585 \u3636 \u3604 \u3586 \u3638 \u3657 \u3609 \u3585 \u3633 \u3610 \u3648 \u3619 \u3634 \u3607 \u3640 \u3585 \u3623 \u3633 \u3609  \u3649 \u3605 \u3656 \u3617 \u3640 \u3617 \u3617 \u3629 \u3591 \u3586 \u3629 \u3591 \u3648 \u3619 \u3634 \u3648 \u3611 \u3621 \u3637 \u3656 \u3618 \u3609 \u3652 \u3611 \u3629 \u3618 \u3656 \u3634 \u3591 \u3626 \u3636 \u3657 \u3609 \u3648 \u3594 \u3636 \u3591  \u3648 \u3614 \u3637 \u3618 \u3591 \u3649 \u3588 \u3656 \u3648 \u3611 \u3636 \u3604 \u3651 \u3592 \u3649 \u3621 \u3632 \u3651 \u3594 \u3657 \u3651 \u3592 \u3651 \u3609 \u3585 \u3634 \u3619 \u3588 \u3657 \u3609 \u3627 \u3634  \u3588 \u3640 \u3603 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3614 \u3610 \u3585 \u3633 \u3610 \u3626 \u3636 \u3656 \u3591 \u3648 \u3627 \u3621 \u3656 \u3634 \u3609 \u3637 \u3657 \u3652 \u3604 \u3657 \u3652 \u3617 \u3656 \u3618 \u3634 \u3585 \u3609 \u3633 \u3585 \
\
\uc0\u3648 \u3617 \u3639 \u3656 \u3629 \u3648 \u3623 \u3621 \u3634 \u3612 \u3656 \u3634 \u3609 \u3652 \u3611 \u3619 \u3632 \u3618 \u3632 \u3648 \u3623 \u3621 \u3634 \u3627 \u3609 \u3638 \u3656 \u3591  \u3585 \u3634 \u3619 \u3648 \u3604 \u3636 \u3609 \u3607 \u3634 \u3591 \u3604 \u3657 \u3634 \u3609 \u3592 \u3636 \u3605 \u3623 \u3636 \u3597 \u3597 \u3634 \u3603 \u3586 \u3629 \u3591 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3588 \u3656 \u3629 \u3618 \u3654 \u3648 \u3605 \u3636 \u3610 \u3650 \u3605 \u3586 \u3638 \u3657 \u3609 \u3607 \u3637 \u3621 \u3632 \u3609 \u3636 \u3604  \u3648 \u3617 \u3639 \u3656 \u3629 \u3617 \u3629 \u3591 \u3627 \u3633 \u3609 \u3627 \u3621 \u3633 \u3591 \u3585 \u3621 \u3633 \u3610 \u3652 \u3611 \u3585 \u3655 \u3614 \u3610 \u3623 \u3656 \u3634 \u3605 \u3609 \u3648 \u3629 \u3591 \u3648 \u3604 \u3636 \u3609 \u3617 \u3634 \u3652 \u3585 \u3621 \u3614 \u3629 \u3626 \u3617 \u3588 \u3623 \u3619  \u3649 \u3605 \u3656 \u3617 \u3633 \u3609 \u3617 \u3634 \u3585 \u3614 \u3629 \u3652 \u3627 \u3617 \u3585 \u3633 \u3610 \u3585 \u3634 \u3619 \u3607 \u3637 \u3656 \u3592 \u3632 \u3619 \u3633 \u3610 \u3617 \u3639 \u3629 \u3585 \u3633 \u3610 \u3588 \u3623 \u3634 \u3617 \u3605 \u3634 \u3618 \u3629 \u3633 \u3609 \u3648 \u3623 \u3636 \u3657 \u3591 \u3623 \u3657 \u3634 \u3591  ?\
\
\uc0\u3585 \u3621 \u3633 \u3610 \u3617 \u3634 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3588 \u3623 \u3634 \u3617 \u3605 \u3634 \u3618 \u3629 \u3637 \u3585 \u3588 \u3619 \u3633 \u3657 \u3591  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3617 \u3636 \u3629 \u3634 \u3592 \u3607 \u3619 \u3634 \u3610 \u3652 \u3604 \u3657 \u3623 \u3656 \u3634 \u3609 \u3637 \u3656 \u3588 \u3639 \u3629 \u3585 \u3634 \u3619 \u3648 \u3605 \u3619 \u3637 \u3618 \u3617 \u3605 \u3633 \u3623 \u3605 \u3634 \u3618 \u3607 \u3637 \u3656 \u3606 \u3641 \u3585 \u3605 \u3657 \u3629 \u3591  \u3649 \u3605 \u3656 \u3617 \u3633 \u3609 \u3648 \u3627 \u3617 \u3634 \u3632 \u3626 \u3617 \u3585 \u3633 \u3610 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3648 \u3629 \u3591  \u3629 \u3618 \u3656 \u3634 \u3591 \u3609 \u3657 \u3629 \u3618 \u3648 \u3617 \u3639 \u3656 \u3629 \u3648 \u3623 \u3621 \u3634 \u3609 \u3633 \u3657 \u3609 \u3617 \u3634 \u3606 \u3638 \u3591  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3585 \u3655 \u3588 \u3591 \u3626 \u3605 \u3636 \u3649 \u3605 \u3585 \u3648 \u3627 \u3617 \u3639 \u3629 \u3609 \u3648 \u3604 \u3636 \u3617  \u3649 \u3605 \u3656 \u3651 \u3609 \u3607 \u3656 \u3634 \u3617 \u3585 \u3621 \u3634 \u3591 \u3607 \u3632 \u3648 \u3621 \u3614 \u3634 \u3618 \u3640 \u3629 \u3633 \u3609 \u3610 \u3657 \u3634 \u3588 \u3621 \u3633 \u3656 \u3591  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3588 \u3591 \u3617 \u3629 \u3591 \u3648 \u3627 \u3655 \u3609 \u3605 \u3657 \u3609 \u3652 \u3617 \u3657 \u3651 \u3627 \u3597 \u3656 \u3651 \u3627 \u3657 \u3648 \u3585 \u3634 \u3632 \u3629 \u3618 \u3641 \u3656 \u3652 \u3585 \u3621 \u3654  \u3614 \u3629 \u3607 \u3637 \u3656 \u3592 \u3632 \u3614 \u3629 \u3618 \u3638 \u3604 \u3648 \u3627 \u3609 \u3637 \u3656 \u3618 \u3623 \u3652 \u3604 \u3657 \u3610 \u3657 \u3634 \u3591  \u3652 \u3617 \u3656 \u3617 \u3634 \u3585 \u3585 \u3655 \u3609 \u3657 \u3629 \u3618  \u3627 \u3619 \u3639 \u3629 \u3610 \u3634 \u3591 \u3607 \u3637