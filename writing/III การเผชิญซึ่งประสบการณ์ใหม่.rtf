\u3634 \u3618 \u3609 \u3637 \u3657 \u3629 \u3629 \u3585 \u3617 \u3634 \u3648 \u3611 \u3655 \u3609 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3619 \u3660 \u3651 \u3627 \u3657 \u3648 \u3619 \u3634 \u3652 \u3604 \u3657 \u3626 \u3604 \u3633 \u3610 \u3619 \u3633 \u3610 \u3594 \u3617 \u3585 \u3633 \u3609  \u3610 \u3634 \u3591 \u3588 \u3619 \u3633 \u3657 \u3591 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3619 \u3660 \u3610 \u3634 \u3591 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3609 \u3633 \u3657 \u3609 \u3617 \u3637 \u3585 \u3634 \u3619 \u3595 \u3656 \u3629 \u3609 \u3609 \u3633 \u3618 \u3588 \u3623 \u3634 \u3617 \u3627 \u3617 \u3634 \u3618 \u3610 \u3634 \u3591 \u3629 \u3618 \u3656 \u3634 \u3591 \u3652 \u3604 \u3657 \u3629 \u3618 \u3656 \u3634 \u3591 \u3621 \u3638 \u3585 \u3621 \u3633 \u3610 \u3649 \u3621 \u3632 \u3648 \u3593 \u3637 \u3618 \u3610 \u3588 \u3617  \u3607 \u3635 \u3651 \u3627 \u3657 \u3612 \u3641 \u3657 \u3594 \u3617 \u3605 \u3657 \u3629 \u3591 \u3629 \u3629 \u3585 \u3649 \u3619 \u3591 \u3651 \u3594 \u3657 \u3626 \u3605 \u3636 \u3611 \u3633 \u3597 \u3597 \u3634 \u3629 \u3618 \u3656 \u3634 \u3591 \u3614 \u3629 \u3626 \u3617 \u3588 \u3623 \u3619 \u3607 \u3637 \u3656 \u3592 \u3632 \u3652 \u3604 \u3657 \u3588 \u3623 \u3634 \u3617 \u3627 \u3617 \u3634 \u3618 \u3629 \u3633 \u3609 \u3609 \u3637 \u3657 \u3652 \u3611  \u3610 \u3657 \u3634 \u3591 \u3585 \u3655 \u3623 \u3656 \u3634 \u3585 \u3621 \u3656 \u3634 \u3623  \u3604 \u3656 \u3634 \u3607 \u3629  \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3619 \u3660 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3609 \u3637 \u3657 \u3652 \u3611 \u3629 \u3618 \u3656 \u3634 \u3591 \u3652 \u3617 \u3656 \u3651 \u3618 \u3604 \u3637 \u3648 \u3609 \u3639 \u3656 \u3629 \u3591 \u3592 \u3634 \u3585 \u3585 \u3621 \u3640 \u3656 \u3617 \u3612 \u3641 \u3657 \u3594 \u3617 \u3610 \u3634 \u3591 \u3585 \u3621 \u3640 \u3656 \u3617 \u3607 \u3637 \u3656 \u3617 \u3636 \u3629 \u3634 \u3592 \u3592 \u3632 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3648 