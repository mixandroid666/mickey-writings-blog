---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const writings = await getCollection('writings');
writings.sort((a, b) => a.data.number - b.data.number);
---

<Layout title="Mickey's Writing — งานเขียน">
  <section class="hero">
    <h1>งานเขียน</h1>
    <p class="subtitle">บทความและความคิด</p>
  </section>

  <ul class="writing-list">
    {writings.map((piece) => (
      <li class="writing-item">
        <a href={`/writings/${piece.slug}`}>
          <span class="number">
            {['I','II','III','IV','V','VI','VII','VIII'][piece.data.number - 1]}
          </span>
          <div class="writing-info">
            <h2>{piece.data.title}</h2>
            {piece.data.excerpt && (
              <p class="excerpt">{piece.data.excerpt}</p>
            )}
          </div>
          <span class="arrow">→</span>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .hero {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .subtitle {
    color: var(--color-muted);
    font-size: 1rem;
  }

  .writing-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .writing-item a {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .writing-item a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .writing-item a:hover .number {
    color: var(--color-accent);
  }

  .writing-item a:hover .arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  .number {
    font-size: 0.8rem;
    color: var(--color-muted);
    min-width: 2rem;
    padding-top: 0.3rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    transition: color 0.15s ease;
  }

  .writing-info {
    flex: 1;
  }

  h2 {
    font-size: 1.15rem;
    font-weight: 400;
    margin-bottom: 0.4rem;
    line-height: 1.4;
  }

  .excerpt {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .arrow {
    color: var(--color-muted);
    font-size: 1rem;
    padding-top: 0.2rem;
    transition: transform 0.15s ease, color 0.15s ease;
  }
</style>
