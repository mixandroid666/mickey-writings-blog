\uc0\u3588 \u3609 \u3648 \u3619 \u3634 \u3609 \u3633 \u3657 \u3609 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3648 \u3626 \u3614 \u3611 \u3632 \u3607 \u3632 \u3611 \u3619 \u3632 \u3626 \u3610 \u3585 \u3634 \u3619 \u3603 \u3660 \u3651 \u3627 \u3617 \u3656 \u3654 \u3652 \u3604 \u3657 \u3648 \u3614 \u3637 \u3618 \u3591 \u3588 \u3619 \u3633 \u3657 \u3591 \u3648 \u3604 \u3637 \u3618 \u3623 \u3651 \u3609 \u3594 \u3637 \u3623 \u3636 \u3605  \u3651 \u3627 \u3657 \u3648 \u3586 \u3634 \u3612 \u3641 \u3657 \u3609 \u3633 \u3657 \u3609 \u3648 \u3626 \u3614 \u3626 \u3617 \u3604 \u3657 \u3623 \u3618 \u3605 \u3633 \u3623 \u3648 \u3586 \u3634 \u3648 \u3629 \u3591 \u3648 \u3606 \u3636 \u3604  \u3585 \u3634 \u3619 \u3626 \u3611 \u3629 \u3618 \u3617 \u3636 \u3652 \u3604 \u3657 \u3605 \u3656 \u3634 \u3591 \u3592 \u3634 \u3585 \u3585 \u3634 \u3619 \u3590 \u3656 \u3634 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3619 \u3660 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3609 \u3633 \u3657 \u3609 \u3654 \u3651 \u3627 \u3657 \u3605 \u3634 \u3618 \u3649 \u3604 \u3657 \u3604 \u3636 \u3657 \u3609 \u3629 \u3618 \u3656 \u3634 \u3591 \u3609 \u3656 \u3634 \u3648 \u3623 \u3607 \u3609 \u3634  \u3621 \u3629 \u3591 \u3605 \u3619 \u3629 \u3591 \u3604 \u3641 \u3648 \u3606 \u3636 \u3604 \u3623 \u3656 \u3634 \u3612 \u3641 \u3657 \u3626 \u3619 \u3619 \u3588 \u3660 \u3626 \u3619 \u3657 \u3634 \u3591 \u3649 \u3621 \u3632 \u3607 \u3637 \u3617 \u3591 \u3634 \u3609 \u3648 \u3586 \u3634 \u3605 \u3657 \u3629 \u3591 \u3629 \u3629 \u3585 \u3649 \u3619 \u3591 \u3629 \u3629 \u3585 \u3648 \u3591 \u3636 \u3609 \u3648 \u3614 \u3637 \u3618 \u3591 \u3652 \u3627 \u3609 \u3585 \u3623 \u3656 \u3634 \u3592 \u3632 \u3652 \u3604 \u3657 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3654 \u3627 \u3609 \u3638 \u3656 \u3591 \u3629 \u3629 \u3585 \u3617 \u3634 \u3652 \u3604 \u3657  \u3610 \u3634 \u3591 \u3588 \u3619 \u3633 \u3657 \u3591 \u3612 \u3641 \u3657 \u3594 \u3617 \u3612 \u3641 \u3657 \u3609 \u3633 \u3657 \u3609 \u3629 \u3634 \u3592 \u3592 \u3632 \u3652 \u3604 \u3657 \u3619 \u3633 \u3610 \u3616 \u3634 \u3614 \u3626 \u3632 \u3607 \u3657 \u3629 \u3609 \u3627 \u3619 \u3639 \u3629  \'93\u3588 \u3623 \u3634 \u3617 \u3627 \u3617 \u3634 \u3618 \'94 \u3610 \u3634 \u3591 \u3629 \u3618 \u3656 \u3634 \u3591 \u3607 \u3637 \u3656 \u3652 \u3604 \u3657 \u3617 \u3634 \u3592 \u3634 \u3585  \'93\u3611 \u3619 \u3632 \u3626 \u3610 \u3585 \u3634 \u3619 \u3603 \u3660 \u3626 \u3604 \u3651 \u3627 \u3617 \u3656 \u3588 \u3619 \u3633 \u3657 \u3591 \u3649 \u3619 \u3585 \'94 \u3592 \u3634 \u3585 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3619 \u3660  \u3595 \u3638 \u3656 \u3591 \u3629 \u3634 \u3592 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3648 \u3611 \u3621 \u3637 \u3656 \u3618 \u3609 \u3594 \u3637 \u3623 \u3636 \u3605 \u3648 \u3586 \u3657 \u3634 \u3652 \u3604 \u3657 \u3648 \u3607 \u3637 \u3618 \u3623  \u3614 \u3623 \u3585 \u3607 \u3656 \u3634 \u3609 \u3648 \u3627 \u3655 \u3609 \u3652 \u3627 \u3617 \u3623 \u3656 \u3634 \u3609 \u3629 \u3585 \u3592 \u3634 \u3585 \u3585 \u3634 \u3619 \u3626 \u3611 \u3629 \u3618 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3660 \u3592 \u3632 \u3590 \u3656 \u3634 \u3605 \u3633 \u3623 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3660 \u3648 \u3629 \u3591 \u3649 \u3621 \u3657 \u3623 \u3649 \u3605 \u3656 \u3618 \u3633 \u3591 \u3590 \u3656 \u3634 \u3650 \u3629 \u3585 \u3634 \u3626 \u3651 \u3627 \u3657 \u3649 \u3585 \u3656 \u3612 \u3641 \u3657 \u3588 \u3609 \u3607 \u3637 \u3656 \u3617 \u3636 \u3607 \u3619 \u3634 \u3610 \u3629 \u3636 \u3650 \u3627 \u3609 \u3656 \u3629 \u3636 \u3648 \u3627 \u3609 \u3656 \u3604 \u3657 \u3623 \u3618 \
\
\uc0\u3614 \u3623 \u3585 \u3607 \u3656 \u3634 \u3609 \u3592 \u3591 \u3627 \u3621 \u3637 \u3585 \u3648 \u3621 \u3637 \u3656 \u3618 \u3591 \u3585 \u3634 \u3619 \u3619 \u3633 \u3610 \u3594 \u3617 \u3626 \u3611 \u3629 \u3618 \u3649 \u3621 \u3632 \u3626 \u3611 \u3629 \u3618 \u3660 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3619 \u3660 \u3648 \u3606 \u3636 \u3604  (\u3619 \u3623 \u3617 \u3606 \u3638 \u3591 \u3626 \u3636 \u3656 \u3591 \u3629 \u3639 \u3656 \u3609 \u3654 \u3604 \u3657 \u3623 \u3618 \u3606 \u3657 \u3634 \u3648 \u3611 \u3655 \u3609 \u3652 \u3611 \u3652 \u3604 \u3657  \u3648 \u3594 \u3656 \u3609 \u3648 \u3614 \u3621 \u3591  \u3609 \u3636 \u3618 \u3634 \u3618 ) \u3606 \u3639 \u3629 \u3623 \u3656 \u3634 \u3648 \u3617 \u3605 \u3605 \u3634 \u3649 \u3585 \u3656 \u3626 \u3619 \u3619 \u3614 \u3626 \u3633 \u3605 \u3623 \u3660 \u3607 \u3633 \u3657 \u3591 \u3627 \u3621 \u3634 \u3618  \u3592 \u3591 \u3610 \u3641 \u3594 \u3634 \u3588 \u3623 \u3634 \u3617 \u3652 \u3617 \u3656 \u3619 \u3641 \u3657 \u3649 \u3621 \u3632 \u3618 \u3636 \u3609 \u3604 \u3637 \u3594 \u3639 \u3656 \u3609 \u3617 \u3639 \u3656 \u3609 \u3611 \u3632 \u3607 \u3632 \u3585 \u3633 \u3610 \u3611 \u3619 \u3632 \u3626 \u3610 \u3585 \u3634 \u3619 \u3603 \u3660 \u3651 \u3627 \u3617 \u3656 \u3604 \u3657 \u3623 \u3618 \u3605 \u3633 \u3623 \u3614 \u3623 \u3585 \u3607 \u3656 \u3634 \u3609 \u3648 \u3629 \u3591 \u3648 \u3606 \u3636 \u3604  \u3648 \u3614 \u3619 \u3634 \u3632 \u3609 \u3637 \u3656 \u3588 \u3639 \u3629 \u3594 \u3637 \u3623 \u3636 \u3605  \u3594 \u3637 \u3623 \u3636 \u3605 \u3595 \u3638 \u3656 \u3591 \u3617 \u3636 \u3629 \u3634 \u3592 \u3619 \u3641 \u3657 \u3652 \u3604 \u3657 \u3623 \u3656 \u3634 \u3592 \u3632 \u3617 \u3637 \u3629 \u3637 \u3585 \u3652 \u3627 \u3617 \u3651 \u3609 \u3594 \u3634 \u3605 \u3636 \u3627 \u3609 \u3657 \u3634  \u3611 \u3619 \u3632 \u3626 \u3610 \u3585 \u3634 \u3619 \u3603 \u3660 \u3588 \u3639 \u3629 \u3626 \u3636 \u3656 \u3591 \u3624 \u3633 \u3585 \u3604 \u3636 \u3660 \u3626 \u3636 \u3607 \u3608 \u3636 \u3660 \u3649 \u3621 \u3632 \u3623 \u3636 \u3648 \u3624 \u3625  \u3586 \u3657 \u3634 \u3614 \u3648 \u3586 \u3657 \u3634 \u3651 \u3588 \u3619 \u3656 \u3586 \u3629 \u3651 \u3627 \u3657 \u3614 \u3623 \u3585 \u3607 \u3656 \u3634 \u3609 \u3648 \u3586 \u3657 \u3634 \u3651 \u3592 \u3651 \u3609 \u3592 \u3640 \u3604 \u3609 \u3637 \u3657 }