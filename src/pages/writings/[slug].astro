---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const writings = await getCollection('writings');
  return writings.map((piece) => ({
    params: { slug: piece.slug },
    props: { piece },
  }));
}

const { piece } = Astro.props;
const { Content } = await piece.render();

const romanNumerals = ['I','II','III','IV','V','VI','VII','VIII'];
const numeral = romanNumerals[piece.data.number - 1];
---

<Layout title={`${piece.data.title} — Mickey's Writing`} description={piece.data.excerpt}>
  <article>
    <header class="article-header">
      <a href="/" class="back-link">← กลับ</a>
      <div class="piece-label">
        <span class="numeral">{numeral}</span>
      </div>
      <h1>{piece.data.title}</h1>
    </header>

    <div class="content">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/" class="back-link">← กลับไปหน้าหลัก</a>
    </footer>
  </article>
</Layout>

<style>
  article {
    max-width: 100%;
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-bottom: 2rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .piece-label {
    margin-bottom: 0.75rem;
  }

  .numeral {
    font-size: 0.85rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
  }

  h1 {
    font-size: 1.8rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text);
  }

  .content {
    font-size: 1rem;
    line-height: 2;
    color: var(--color-text);
  }

  .content :global(p) {
    margin-bottom: 1.5rem;
  }

  .content :global(p:last-child) {
    margin-bottom: 0;
  }

  .content :global(em) {
    color: var(--color-muted);
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
</style>
