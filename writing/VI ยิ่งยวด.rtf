5 \u3636 \u3617 \u3648 \u3605 \u3655 \u3617  \u3619 \u3629 \u3585 \u3634 \u3619 \u3649 \u3605 \u3656 \u3591 \u3649 \u3605 \u3657 \u3617  \u3649 \u3621 \u3632 \u3648 \u3619 \u3634 \u3585 \u3655 \u3652 \u3604 \u3657 \u3611 \u3619 \u3640 \u3591 \u3649 \u3605 \u3656 \u3591 \u3629 \u3634 \u3618 \u3605 \u3609 \u3632 \u3586 \u3629 \u3591 \u3605 \u3609 \u3648 \u3629 \u3591 \u3629 \u3618 \u3656 \u3634 \u3591 \u3648 \u3605 \u3655 \u3617 \u3607 \u3637 \u3656 \u3649 \u3621 \u3632 \u3626 \u3609 \u3640 \u3585 \u3626 \u3609 \u3634 \u3609 \
\
\uc0\u3627 \u3609 \u3638 \u3656 \u3591 \u3651 \u3609 \u3611 \u3619 \u3632 \u3626 \u3610 \u3585 \u3634 \u3619 \u3603 \u3660 \u3607 \u3637 \u3656 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3619 \u3641 \u3657 \u3626 \u3638 \u3585  \'93\u3614 \u3629 \u3651 \u3592 \'94 \u3649 \u3621 \u3632  \'93\u3618 \u3636 \u3609 \u3604 \u3637 \'94 \u3629 \u3618 \u3656 \u3634 \u3591 \u3618 \u3636 \u3656 \u3591  \u3588 \u3639 \u3629 \u3585 \u3634 \u3619 \u3652 \u3604 \u3657 \u3588 \u3657 \u3609 \u3614 \u3610 \u3626 \u3636 \u3656 \u3591 \u3607 \u3637 \u3656 \u3648 \u3619 \u3637 \u3618 \u3585 \u3623 \u3656 \u3634  \'93\u3604 \u3609 \u3605 \u3619 \u3637 \'94\
\
\uc0\u3604 \u3609 \u3605 \u3619 \u3637 \u3609 \u3633 \u3657 \u3609  \u3588 \u3639 \u3629 \u3585 \u3634 \u3619 \u3609 \u3635 \u3588 \u3621 \u3639 \u3656 \u3609 \u3648 \u3626 \u3637 \u3618 \u3591 \u3627 \u3621 \u3634 \u3585 \u3627 \u3621 \u3634 \u3618 \u3588 \u3623 \u3634 \u3617 \u3606 \u3637 \u3656 \u3617 \u3634 \u3648 \u3619 \u3637 \u3618 \u3591 \u3619 \u3657 \u3629 \u3618  \u3606 \u3633 \u3585 \u3607 \u3629  \u3649 \u3621 \u3632 \u3611 \u3619 \u3632 \u3626 \u3634 \u3609 \u3585 \u3633 \u3609  \u3648 \u3617 \u3639 \u3656 \u3629 \u3585 \u3619 \u3632 \u3607 \u3635 \u3652 \u3604 \u3657 \u3629 \u3618 \u3656 \u3634 \u3591 \u3614 \u3629 \u3648 \u3627 \u3617 \u3634 \u3632  \u3585 \u3655 \u3592 \u3632 \u3585 \u3656 \u3629 \u3648 \u3585 \u3636 \u3604 \u3588 \u3623 \u3634 \u3617 \u3621 \u3591 \u3605 \u3633 \u3623 \u3629 \u3633 \u3609 \u3591 \u3604 \u3591 \u3634 \u3617  \u3648 \u3611 \u3655 \u3609  \'93\u3588 \u3623 \u3634 \u3617 \u3652 \u3614 \u3648 \u3619 \u3634 \u3632 \'94 \u3607 \u3637 \u3656 \u3648 \u3585 \u3636 \u3604 \u3586 \u3638 \u3657 \u3609 \u3648 \u3617 \u3639 \u3656 \u3629 \u3588 \u3621 \u3639 \u3656 \u3609 \u3648 \u3626 \u3637 \u3618 \u3591 \u3648 \u3627 \u3621 \u3656 \u3634 \u3609 \u3633 \u3657 \u3609 \u3617 \u3634 \u3585 \u3619 \u3632 \u3607 \u3610 \u3650 \u3626 \u3605 \u3611 \u3619 \u3632 \u3626 \u3634 \u3607 \
\
\uc0\u3629 \u3609 \u3638 \u3656 \u3591  \u3585 \u3634 \u3619 \u3592 \u3633 \u3604 \u3623 \u3634 \u3591 \u3650 \u3609 \u3657 \u3605 \u3648 \u3627 \u3621 \u3656 \u3634 \u3609 \u3637 \u3657  \u3616 \u3634 \u3618 \u3627 \u3621 \u3633 \u3591 \u3617 \u3637 \u3594 \u3639 \u3656 \u3629 \u3648 \u3619 \u3637 \u3618 \u3585 \u3623 \u3656 \u3634  \'93\u3588 \u3629 \u3619 \u3660 \u3604 \'94 \u3595 \u3638 \u3656 \u3591 \u3650 \u3604 \u3618 \u3614 \u3639 \u3657 \u3609 \u3600 \u3634 \u3609 \u3588 \u3639 \u3629 \u3585 \u3634 \u3619 \u3609 \u3635 \u3650 \u3609 \u3657 \u3605 \u3605 \u3656 \u3634 \u3591 \u3619 \u3632 \u3604 \u3633 \u3610 \u3585 \u3633 \u3609 \u3629 \u3618 \u3656 \u3634 \u3591 \u3609 \u3657 \u3629 \u3618 \u3626 \u3634 \u3617 \u3648 \u3626 \u3637 \u3618 \u3591 \u3617 \u3634 \u3610 \u3619 \u3619 \u3648 \u3621 \u3591 \u3614 \u3619 \u3657 \u3629 \u3617 \u3585 \u3633 \u3609  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3614 \u3610 \u3623 \u3656 \u3634 \u3626 \u3636 \u3656 \u3591 \u3609 \u3637 \u3657 \u3607 \u3633 \u3657 \u3591 \u3621 \u3638 \u3585 \u3621 \u3633 \u3610 \u3649 \u3621 \u3632 \u3609 \u3656 \u3634 \u3593 \u3591 \u3609 \u3618 \u3636 \u3656 \u3591  \u3648 \u3619 \u3634 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3648 \u3614 \u3636 \u3656 \u3617 \u3650 \u3609 \u3657 \u3605 \u3648 \u3611 \u3655 \u3609 \u3605 \u3633 \u3623 \u3607 \u3637 \u3656 \u3626 \u3634 \u3617  \u3607 \u3637 \u3656 \u3626 \u3637 \u3656  \u3627 \u3619 \u3639 \u3629 \u3617 \u3634 \u3585 \u3585 \u3623 \u3656 \u3634 \u3609 \u3633 \u3657 \u3609  \u3649 \u3621 \u3632 \u3607 \u3640 \u3585 \u3588 \u3619 \u3633 \u3657 \u3591 \u3607 \u3637 \u3656 \u3648 \u3614 \u3636 \u3656 \u3617 \u3648 \u3586 \u3657 \u3634 \u3652 \u3611  \u3585 \u3621 \u3633 \u3610 \u3651 \u3627 \u3657 \u3588 \u3623 \u3634 \u3617 \u3619 \u3641 \u3657 \u3626 \u3638 \u3585 \u3607 \u3637 \u3656 \u3649 \u3605 \u3585 \u3605 \u3656 \u3634 \u3591 \u3629 \u3629 \u3585 \u3652 \u3611 \u3629 \u3618 \u3656 \u3634 \u3591 \u3609 \u3656 \u3634 \u3629 \u3633 \u3624 \u3592 \u3619 \u3619 \u3618 \u3660  \u3619 \u3634 \u3623 \u3585 \u3633 \u3610 \u3623 \u3656 \u3634 \u3588 \u3623 \u3634 \u3617 \u3626 \u3640 \u3586 \u3594 \u3609 \u3636 \u3604 \u3627 \u3609 \u3638 \u3656 \u3591 \u3652 \u3604 \u3657 \u3606 \u3639 \u3629 \u3585 \u3635 \u3648 \u3609 \u3636 \u3604 \u3586 \u3638 \u3657 \u3609  \u3648 \u3611 \u3655 \u3609 \u3588 \u3623 \u3634 \u3617 \u3626 \u3640 \u3586 \u3607 \u3637 \u3656 \u3621 \u3632 \u3648 \u3629 \u3637 \u3618 \u3604 \u3629 \u3656 \u3629 \u3609  \u3605 \u3657 \u3629 \u3591 \u3629 \u3634 \u3624 \u3633 \u3618 \u3616 \u3634 \u3594 \u3609 \u3632 \u3586 \u3629 \u3591 \u3585 \u3634 \u3619 \u3619 \u3633 \u3610 \u3619 \u3641 \u3657 \u3607 \u3637 \u3656 \u3621 \u3638 \u3585 \u3614 \u3629 \u3592 \u3638 \u3591 \u3592 \u3632 \u3648 \u3586 \u3657 \u3634 \u3606 \u3638 \u3591 \u3652 \u3604 \u3657 \
\
\uc0\u3649 \u3621 \u3632 \u3617 \u3636 \u3651 \u3594 \u3656 \u3648 \u3614 \u3637 \u3618 \u3591 \u3604 \u3609 \u3605 \u3619 \u3637 \u3648 \u3607 \u3656 \u3634 \u3609 \u3633 \u3657 \u3609  \u3611 \u3619 \u3632 \u3626 \u3610 \u3585 \u3634 \u3619 \u3603 \u3660 \u3629 \u3639 \u3656 \u3609  \u3654  \u3585 \u3655 \u3651 \u3627 \u3657 \u3588 \u3623 \u3634 \u3617 \u3619 \u3641 \u3657 \u3626 \u3638 \u3585 \u3588 \u3621 \u3657 \u3634 \u3618 \u3588 \u3621 \u3638 \u3591 \u3585 \u3633 \u3609  \u3652 \u3617 \u3656 \u3623 \u3656 \u3634 \u3592 \u3632 \u3648 \u3611 \u3655 \u3609 \u3585 \u3634 \u3619 \u3652 \u3604 \u3657 \u3586 \u3638 \u3657 \u3609 \u3648 \u3588 \u3619 \u3639 \u3656 \u3629 \u3591 \u3610 \u3636 \u3609 \u3648 \u3611 \u3655 \u3609 \u3588 \u3619 \u3633 \u3657 \u3591 \u3649 \u3619 \u3585  \u3585 \u3634 \u3619 \u3652 \u3604 \u3657 \u3594 \u3617 \u3616 \u3634 \u3614 \u3618 \u3609 \u3605 \u3619 \u3660 \u3607 \u3637 \u3656 \u3604 \u3637  \u3585 \u3634 \u3619 \u3626 \u3617 \u3627 \u3623 \u3633 \u3591  \u3627 \u3619 \u3639 \u3629 \u3649 \u3617 \u3657 \u3649 \u3605 \u3656 \u3585 \u3634 \u3619 \u3652 \u3604 \u3657 \u3619 \u3633 \u3610 \u3594 \u3633 \u3618 \u3594 \u3609 \u3632 \
\
\uc0\u3607 \u3623 \u3656 \u3634 \u3648 \u3617 \u3639 \u3656 \u3629 \u3629 \u3634 \u3618 \u3640 \u3617 \u3634 \u3585 \u3586 \u3638 \u3657 \u3609  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3585 \u3621 \u3633 \u3610 \u3614 \u3610 \u3623 \u3656 \u3634  \'93\u3616 \u3634 \u3594 \u3609 \u3632 \'94 \u3607 \u3637 \u3656 \u3651 \u3594 \u3657 \u3619 \u3629 \u3591 \u3619 \u3633 \u3610 \u3588 \u3623 \u3634 \u3617 \u3619 \u3641 \u3657 \u3626 \u3638 \u3585 \u3648 \u3627 \u3621 \u3656 \u3634 \u3609 \u3637 \u3657  \u3605 \u3657 \u3629 \u3591 \u3585 \u3634 \u3619 \u3626 \u3636 \u3656 \u3591 \u3607 \u3637 \u3656  \'93\u3648 \u3627 \u3609 \u3639 \u3629 \u3586 \u3638 \u3657 \u3609 \u3652 \u3611 \'94 \u3585 \u3623 \u3656 \u3634 \u3626 \u3636 \u3656 \u3591 \u3607 \u3637 \u3656 \u3648 \u3588 \u3618 \u3648 \u3611 \u3655 \u3609 \u3617 \u3634  \u3629 \u3634 \u3592 \u3585 \u3621 \u3656 \u3634 \u3623 \u3652 \u3604 \u3657 \u3623 \u3656 \u3634 \u3609 \u3637 \u3656 \u3588 \u3621 \u3657 \u3634 \u3618 \u3585 \u3633 \u3610 \u3585 \u3634 \u3619 \u3648 \u3626 \u3614 \u3605 \u3636 \u3604 \u3619 \u3641 \u3611 \u3649 \u3610 \u3610 \u3627 \u3609 \u3638 \u3656 \u3591  \'97 \u3605 \u3657 \u3629 \u3591 \u3585 \u3634 \u3619 \u3617 \u3634 \u3585 \u3586 \u3638 \u3657 \u3609  \u3649 \u3619 \u3591 \u3586 \u3638 \u3657 \u3609  \u3649 \u3621 \u3632 \u3610 \u3656 \u3629 \u3618 \u3586 \u3638 \u3657 \u3609 \
\
\uc0\u3588 \u3635 \u3606 \u3634 \u3617 \u3592 \u3638 \u3591 \u3648 \u3585 \u3636 \u3604 \u3586 \u3638 \u3657 \u3609 \u3623 \u3656 \u3634  \u3626 \u3636 \u3656 \u3591 \u3651 \u3604 \u3648 \u3621 \u3656 \u3634 \u3592 \u3632 \u3626 \u3634 \u3617 \u3634 \u3619 \u3606 \u3648 \u3605 \u3636 \u3617 \u3648 \u3605 \u3655 \u3617 \u3594 \u3656 \u3629 \u3591 \u3623 \u3656 \u3634 \u3591 \u3609 \u3637 \u3657 \u3652 \u3604 \u3657 \
\
\uc0\u3610 \u3634 \u3591 \u3588 \u3619 \u3633 \u3657 \u3591  \u3588 \u3635 \u3605 \u3629 \u3610 \u3604 \u3641 \u3648 \u3627 \u3617 \u3639 \u3629 \u3609 \u3592 \u3632 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3629 \u3618 \u3641 \u3656 \u3651 \u3609 \u3650 \u3621 \u3585 \u3607 \u3637 \u3656 \u3626 \u3633 \u3617 \u3612 \u3633 \u3626 \u3652 \u3604 \u3657  \u3627 \u3634 \u3585 \u3649 \u3605 \u3656 \u3629 \u3618 \u3641 \u3656 \u3651 \u3609 \u3626 \u3636 \u3656 \u3591 \u3607 \u3637 \u3656  \'93\u3648 \u3627 \u3609 \u3639 \u3629 \u3650 \u3621 \u3585 \'94 \u3617 \u3637 \u3649 \u3609 \u3623 \u3588 \u3636 \u3604 \u3607 \u3634 \u3591 \u3592 \u3636 \u3605 \u3623 \u3636 \u3597 \u3597 \u3634 \u3603 \u3617 \u3634 \u3585 \u3617 \u3634 \u3618 \u3607 \u3637 \u3656 \u3614 \u3618 \u3634 \u3618 \u3634 \u3617 \u3648 \u3626 \u3609 \u3629 \u3605 \u3633 \u3623 \u3648 \u3629 \u3591 \u3623 \u3656 \u3634  \'93\u3586 \u3657 \u3634 \u3588 \u3639 \u3629 \u3588 \u3635 \u3605 \u3629 \u3610 \u3586 \u3629 \u3591 \u3648 \u3592 \u3657 \u3634 \'94 \u3649 \u3621 \u3632 \u3649 \u3605 \u3656 \u3621 \u3632 \u3649 \u3609 \u3623 \u3588 \u3636 \u3604 \u3585 \u3655 \u3648 \u3626 \u3617 \u3639 \u3629 \u3609 \u3626 \u3636 \u3609 \u3588 \u3657 \u3634 \u3651 \u3609 \u3619 \u3657 \u3634 \u3609  \u3607 \u3637 \u3656 \u3623 \u3634 \u3591 \u3648 \u3619 \u3637 \u3618 \u3591 \u3619 \u3634 \u3618 \u3619 \u3629 \u3651 \u3627 \u3657 \u3648 \u3619 \u3634 \u3648 \u3621 \u3639 \u3629 \u3585 \u3626 \u3619 \u3619 \
\
\uc0\u3629 \u3637 \u3585 \u3626 \u3636 \u3656 \u3591 \u3627 \u3609 \u3638 \u3656 \u3591 \u3607 \u3637 \u3656 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3588 \u3657 \u3609 \u3614 \u3610 \u3651 \u3609 \u3616 \u3634 \u3618 \u3627 \u3621 \u3633 \u3591  \u3588 \u3639 \u3629  \u3626 \u3636 \u3656 \u3591 \u3607 \u3637 \u3656 \u3648 \u3585 \u3636 \u3604 \u3586 \u3638 \u3657 \u3609 \u3609 \u3637 \u3657 \u3617 \u3636 \u3651 \u3594 \u3656 \u3648 \u3614 \u3637 \u3618 \u3591 \u3585 \u3634 \u3619 \u3619 \u3633 \u3610 \u3619 \u3641 \u3657 \u3612 \u3656 \u3634 \u3609 \u3629 \u3634 \u3618 \u3605 \u3609 \u3632  \u3627 \u3634 \u3585 \u3649 \u3605 \u3656 \u3648 \u3611 \u3655 \u3609 \u3585 \u3619 \u3632 \u3610 \u3623 \u3609 \u3585 \u3634 \u3619 \u3586 \u3629 \u3591  \'93\u3585 \u3634 \u3619 \u3619 \u3641 \u3657 \'94 \u3607 \u3637 \u3656 \u3648 \u3585 \u3636 \u3604 \u3586 \u3638 \u3657 \u3609 \u3592 \u3634 \u3585  \'93\u3588 \u3623 \u3634 \u3617 \u3652 \u3617 \u3656 \u3619 \u3641 \u3657 \'94\
