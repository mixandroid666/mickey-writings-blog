3633 \u3657 \u3609 \u3654 \u3648 \u3621 \u3618 \u3607 \u3637 \u3648 \u3604 \u3637 \u3618 \u3623  \u3648 \u3617 \u3639 \u3656 \u3629 \u3607 \u3619 \u3634 \u3610 \u3648 \u3609 \u3639 \u3657 \u3629 \u3627 \u3634 \u3585 \u3655 \u3652 \u3611 \u3648 \u3607 \u3637 \u3656 \u3618 \u3623 \u3611 \u3656 \u3634 \u3623 \u3611 \u3619 \u3632 \u3585 \u3634 \u3624 \u3585 \u3633 \u3610 \u3648 \u3614 \u3639 \u3656 \u3629 \u3609 \u3613 \u3641 \u3591 \u3585 \u3633 \u3609 \u3629 \u3618 \u3656 \u3634 \u3591 \u3616 \u3634 \u3588 \u3616 \u3641 \u3617 \u3636 \u3651 \u3592 \u3623 \u3656 \u3634  \'93\u3593 \u3633 \u3609 \u3619 \u3641 \u3657 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3609 \u3637 \u3657 \u3649 \u3621 \u3657 \u3623 \u3609 \u3632  \u3614 \u3623 \u3585 \u3609 \u3634 \u3618 \u3629 \u3618 \u3634 \u3585 \u3619 \u3641 \u3657 \u3652 \u3627 \u3617 \u3621 \u3632 \u3592 \u3632 \u3652 \u3604 \u3657 \u3652 \u3617 \u3656 \u3605 \u3657 \u3629 \u3591 \u3648 \u3626 \u3637 \u3618 \u3605 \u3633 \u3591 \u3652 \u3611 \u3604 \u3641 \u3627 \u3609 \u3633 \u3591 \u3651 \u3627 \u3657 \u3648 \u3626 \u3637 \u3618 \u3648 \u3591 \u3636 \u3609 \u3649 \u3621 \u3648 \u3623 \u3621 \u3634 \'94 \u3649 \u3618 \u3656 \u3652 \u3611 \u3585 \u3623 \u3656 \u3634 \u3609 \u3633 \u3657 \u3609 \u3648 \u3586 \u3634 \u3585 \u3655 \u3650 \u3612 \u3621 \u3656 \u3591 \u3626 \u3611 \u3629 \u3618 \u3609 \u3633 \u3657 \u3609 \u3629 \u3629 \u3585 \u3617 \u3634 \u3650 \u3604 \u3618 \u3607 \u3637 \u3656 \u3612 \u3641 \u3657 \u3615 \u3633 \u3591 \u3617 \u3636 \u3652 \u3604 \u3657 \u3617 \u3637 \u3648 \u3592 \u3605 \u3609 \u3634 \u3605 \u3657 \u3629 \u3591 \u3585 \u3634 \u3619 \u3615 \u3633 \u3591  \u3609 \u3637 \u3656 \u3648 \u3611 \u3655 \u3609 \u3585 \u3634 \u3619 \u3607 \u3635 \u3619 \u3657 \u3634 \u3618 \u3585 \u3633 \u3609 \u3629 \u3618 \u3656 \u3634 \u3591 \u3627 \u3609 \u3638 \u3656 \u3591 \
