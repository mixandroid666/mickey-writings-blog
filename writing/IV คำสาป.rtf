\uc0\u3650 \u3604 \u3618 \u3585 \u3621 \u3640 \u3656 \u3617 \u3594 \u3634 \u3623 \u3614 \u3640 \u3607 \u3608 \u3627 \u3619 \u3639 \u3629 \u3594 \u3634 \u3623 \u3624 \u3634 \u3626 \u3609 \u3634 \u3605 \u3632 \u3623 \u3633 \u3609 \u3629 \u3629 \u3585 \u3650 \u3604 \u3618 \u3626 \u3656 \u3623 \u3609 \u3617 \u3634 \u3585 \u3609 \u3633 \u3657 \u3609 \u3617 \u3633 \u3585 \u3592 \u3632 \u3648 \u3594 \u3639 \u3656 \u3629 \u3616 \u3638 \u3591  \'93\u3588 \u3623 \u3634 \u3617 \u3623 \u3656 \u3634 \u3591 \'94 \u3627 \u3619 \u3639 \u3629  \'93\u3588 \u3623 \u3634 \u3617 \u3652 \u3619 \u3657 \u3605 \u3633 \u3623 \u3605 \u3609 \'94 \u3629 \u3633 \u3609 \u3648 \u3611 \u3655 \u3609 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3651 \u3627 \u3597 \u3656 \u3586 \u3629 \u3591 \u3611 \u3619 \u3633 \u3594 \u3597 \u3634 \u3649 \u3606 \u3610 \u3609 \u3637 \u3657  \u3652 \u3617 \u3656 \u3623 \u3656 \u3634 \u3592 \u3632 \u3648 \u3611 \u3655 \u3609  \'93\u3609 \u3636 \u3614 \u3614 \u3634 \u3609 \'94 \'93\u3609 \u3619 \u3636 \u3623 \u3634 \u3603 \'94 \'93\u3648 \u3605 \u3659 \u3634 \'94 \u3627 \u3619 \u3639 \u3629  \'93\u3629 \u3609 \u3633 \u3605 \u3605 \u3634 \'94 \u3621 \u3657 \u3623 \u3609 \u3652 \u3617 \u3656 \u3617 \u3637 \u3585 \u3634 \u3619 \u3648 \u3585 \u3637 \u3656 \u3618 \u3623 \u3586 \u3657 \u3629 \u3591 \u3585 \u3633 \u3610 \u3588 \u3629 \u3609 \u3648 \u3595 \u3655 \u3611 \u3586 \u3629 \u3591 \u3588 \u3635 \u3623 \u3656 \u3634  \'93\u3614 \u3619 \u3632 \u3648 \u3592 \u3657 \u3634 \u3612 \u3641 \u3657 \u3629 \u3633 \u3609 \u3648 \u3611 \u3655 \u3609 \u3612 \u3641 \u3657 \u3648 \u3619 \u3636 \u3656 \u3617 \u3605 \u3657 \u3609 \u3649 \u3621 \u3632 \u3612 \u3641 \u3657 \u3648 \u3611 \u3655 \u3609 \u3592 \u3640 \u3604 \u3592 \u3610 \'94 \u3648 \u3621 \u3618  \u3614 \u3623 \u3585 \u3648 \u3586 \u3634 \u3648 \u3594 \u3639 \u3656 \u3629 \u3623 \u3656 \u3634 \u3652 \u3617 \u3656 \u3623 \u3656 \u3634 \u3592 \u3632 \u3617 \u3637 \u3627 \u3619 \u3639 \u3629 \u3652 \u3617 \u3656 \u3617 \u3637 \u3614 \u3619 \u3632 \u3648 \u3592 \u3657 \u3634 \u3609 \u3633 \u3657 \u3609  \u3585 \u3655 \u3617 \u3636 \u3652 \u3604 \u3657 \u3586 \u3657 \u3629 \u3591 \u3648 \u3585 \u3637 \u3656 \u3618 \u3623 \u3585 \u3633 \u3610 \u3585 \u3634 \u3619 \u3627 \u3621 \u3640 \u3604 \u3614 \u3657 \u3609 \u3586 \u3629 \u3591 \u3614 \u3623 \u3585 \u3648 \u3586 \u3634 \u3652 \u3617 \u3656  \u3626 \u3636 \u3656 \u3591 \u3648 \u3627 \u3621 \u3656 \u3634 \u3609 \u3637 \u3657 \u3607 \u3635 \u3651 \u3627 \u3657 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \u3586 \u3629 \u3591 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3626 \u3633 \u3656 \u3609 \u3588 \u3621 \u3629 \u3609  \u3650 \u3604 \u3618 \u3618 \u3656 \u3629 \u3585 \u3655 \u3588 \u3639 \u3629  \u3588 \u3619 \u3638 \u3656 \u3591 \u3627 \u3609 \u3638 \u3656 \u3591 \u3629 \u3618 \u3641 \u3656 \u3585 \u3633 \u3610 \u3614 \u3619 \u3632 \u3648 \u3592 \u3657 \u3634  \u3629 \u3637 \u3585 \u3588 \u3619 \u3638 \u3656 \u3591 \u3627 \u3609 \u3638 \u3656 \u3591 \u3585 \u3655 \u3629 \u3618 \u3641 \u3656 \u3585 \u3633 \u3610 \u3609 \u3636 \u3614 \u3614 \u3634 \u3609  \u3592 \u3632 \u3623 \u3656 \u3634 \u3629 \u3618 \u3656 \u3634 \u3591 \u3609 \u3633 \u3657 \u3609 \u3585 \u3655 \u3618 \u3656 \u3629 \u3617 \u3652 \u3604 \u3657 \
\uc0\u3604 \u3633 \u3591 \u3609 \u3633 \u3657 \u3609 \u3626 \u3636 \u3656 \u3591 \u3609 \u3637 \u3657 \u3649 \u3627 \u3621 \u3632 \u3588 \u3639 \u3629  \u3588 \u3635 \u3626 \u3634 \u3611 \u3586 \u3629 \u3591 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3652 \u3617 \u3656 \u3648 \u3604 \u3655 \u3604 \u3648 \u3604 \u3637 \u3618 \u3623 \u3614 \u3629 \u3607 \u3637 \u3656 \u3592 \u3632 \u3648 \u3621 \u3639 \u3629 \u3585 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \u3651 \u3604 \u3588 \u3623 \u3634 \u3617 \u3648 \u3594 \u3639 \u3656 \u3629 \u3627 \u3609 \u3638 \u3656 \u3591  \u3607 \u3634 \u3591 \u3604 \u3657 \u3634 \u3609 \u3614 \u3619 \u3632 \u3648 \u3592 \u3657 \u3634 \u3609 \u3633 \u3657 \u3609  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3585 \u3655 \u3648 \u3594 \u3639 \u3656 \u3629 \u3623 \u3656 \u3634 \u3629 \u3634 \u3592 \u3617 \u3637 \u3629 \u3618 \u3641 \u3656 \u3592 \u3619 \u3636 \u3591  \u3649 \u3605 \u3656 \u3629 \u3637 \u3585 \u3607 \u3634 \u3591 \u3627 \u3609 \u3638 \u3656 \u3591 \u3585 \u3655 \u3610 \u3629 \u3585 \u3623 \u3656 \u3634 \u3609 \u3637 \u3656 \u3617 \u3636 \u3651 \u3594 \u3656 \u3585 \u3634 \u3619 \u3627 \u3621 \u3640 \u3604 \u3614 \u3657 \u3609  \u3649 \u3618 \u3656 \u3652 \u3611 \u3609 \u3633 \u3657 \u3609 \u3585 \u3655 \u3606 \u3639 \u3629 \u3623 \u3656 \u3634 \u3648 \u3611 \u3655 \u3609 \u3629 \u3623 \u3636 \u3594 \u3594 \u3634 \u3648 \u3621 \u3618 \u3607 \u3637 \u3648 \u3604 \u3637 \u3618 \u3623  \u3648 \u3611 \u3655 \u3609 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3648 \u3627 \u3621 \u3623 \u3652 \u3627 \u3621  \u3617 \u3636 \u3623 \u3656 \u3634 \u3626 \u3636 \u3656 \u3591 \u3651 \u3604 \u3609 \u3633 \u3657 \u3609 \u3618 \u3656 \u3629 \u3617 \u3605 \u3585 \u3629 \u3618 \u3641 \u3656 \u3651 \u3609 \u3627 \u3621 \u3633 \u3585 \u3652 \u3605 \u3619 \u3621 \u3633 \u3585 \u3625 \u3603 \u3660  (\u3629 \u3609 \u3636 \u3592 \u3592 \u3633 \u3591  \u3607 \u3640 \u3585 \u3586 \u3633 \u3591  \u3629 \u3609 \u3633 \u3605 \u3605 \u3634 ) \u3649 \u3605 \u3656 \u3615 \u3633 \u3591 \u3614 \u3619 \u3632 \u3648 \u3592 \u3657 \u3634 \u3585 \u3655 \u3651 \u3627 \u3657 \u3588 \u3623 \u3634 \u3617 \u3648 \u3627 \u3655 \u3609 \u3623 \u3656 \u3634  \u3626 \u3636 \u3656 \u3591 \u3607 \u3637 \u3656 \u3607 \u3656 \u3634 \u3609 \u3648 \u3586 \u3657 \u3634 \u3651 \u3592  \u3603  \u3605 \u3629 \u3609 \u3609 \u3637 \u3657 \u3609 \u3633 \u3657 \u3609  \u3648 \u3611 \u3655 \u3609 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3586 \u3629 \u3591 \u3595 \u3634 \u3605 \u3634 \u3605  (\u3617 \u3634 \u3619 ) \u3607 \u3637 \u3656 \u3617 \u3634 \u3621 \u3656 \u3629 \u3621 \u3623 \u3591  \u3614 \u3623 \u3585 \u3607 \u3656 \u3634 \u3609 \u3592 \u3591 \u3629 \u3618 \u3656 \u3634 \u3652 \u3611 \u3626 \u3609 \u3607 \u3609 \u3634 \u3585 \u3633 \u3610 \u3617 \u3633 \u3609  \u3585 \u3634 \u3619 \u3648 \u3594 \u3639 \u3656 \u3629 \u3614 \u3619 \u3632 \u3648 \u3592 \u3657 \u3634 \u3648 \u3614 \u3637 \u3618 \u3591 \u3612 \u3641 \u3657 \u3648 \u3604 \u3637 \u3618 \u3623 \u3609 \u3633 \u3657 \u3609  \u3588 \u3639 \u3629 \u3607 \u3634 \u3591 \u3627 \u3621 \u3640 \u3604 \u3614 \u3657 \u3609 \u3629 \u3618 \u3656 \u3634 \u3591 \u3649 \u3607 \u3657 \u3592 \u3619 \u3636 \u3591 \
\uc0\u3652 \u3604 \u3657 \u3650 \u3611 \u3619 \u3604 \u3648 \u3606 \u3636 \u3604 \u3607 \u3656 \u3634 \u3609 \u3607 \u3633 \u3657 \u3591 \u3627 \u3621 \u3634 \u3618  \u3651 \u3609 \u3648 \u3623 \u3621 \u3634 \u3607 \u3637 \u3656 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3585 \u3635 \u3621 \u3633 \u3591 \u3592 \u3632 \u3605 \u3634 \u3618 \u3627 \u3619 \u3639 \u3629 \u3605 \u3634 \u3618 \u3652 \u3611 \u3649 \u3621 \u3657 \u3623 \u3609 \u3633 \u3657 \u3609 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3586 \u3629 \u3651 \u3588 \u3619 \u3656 \u3588 \u3619 \u3623 \u3597  \u3629 \u3657 \u3629 \u3609 \u3623 \u3629 \u3609 \u3614 \u3623 \u3585 \u3648 \u3607 \u3656 \u3634  \u3614 \u3623 \u3585 \u3609 \u3638 \u3591 \u3651 \u3627 \u3657 \u3626 \u3623 \u3604 \u3617 \u3609 \u3605 \u3660  \u3609 \u3633 \u3656 \u3591 \u3626 \u3617 \u3634 \u3608 \u3636  \u3629 \u3640 \u3607 \u3636 \u3624 \u3610 \u3640 \u3597 \u3585 \u3640 \u3624 \u3621  \u3651 \u3627 \u3657 \u3649 \u3585 \u3656 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3604 \u3657 \u3623 \u3610  \u3629 \u3637 \u3585 \u3614 \u3623 \u3585 \u3609 \u3638 \u3591 \u3586 \u3629 \u3651 \u3627 \u3657 \u3614 \u3623 \u3585 \u3607 \u3656 \u3634 \u3609 \u3586 \u3629 \u3629 \u3657 \u3629 \u3609 \u3623 \u3629 \u3609 \u3614 \u3619 \u3632 \u3612 \u3641 \u3657 \u3648 \u3611 \u3655 \u3609 \u3648 \u3592 \u3657 \u3634 \u3651 \u3627 \u3657 \u3629 \u3616 \u3633 \u3618 \u3649 \u3585 \u3656 \u3586 \u3657 \u3634 \u3604 \u3657 \u3623 \u3618  \u3604 \u3657 \u3623 \u3618 \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3609 \u3633 \u3657 \u3609 \u3617 \u3636 \u3605 \u3657 \u3629 \u3591 \u3585 \u3634 \u3619 \u3605 \u3585 \u3609 \u3619 \u3585 \u3627 \u3617 \u3585 \u3652 \u3627 \u3617 \u3657  \u3594 \u3633 \u3656 \u3623 \u3585 \u3633 \u3611 \u3594 \u3633 \u3656 \u3623 \u3585 \u3619 \u3619 \u3611 \u3660  \u3586 \u3657 \u3634 \u3614 \u3648 \u3592 \u3657 \u3634 \u3586 \u3629 \u3588 \u3623 \u3634 \u3617 \u3648 \u3617 \u3605 \u3605 \u3634 \u3592 \u3634 \u3585 \u3607 \u3656 \u3634 \u3609  \u3650 \u3611 \u3619 \u3604 \u3648 \u3627 \u3655 \u3609 \u3651 \u3592 \u3626 \u3633 \u3605 \u3623 \u3660 \u3648 \u3604 \u3619 \u3633 \u3592 \u3593 \u3634 \u3609 \u3627 \u3619 \u3639 \u3629 \u3626 \u3633 \u3605 \u3623 \u3660 \u3611 \u3619 \u3632 \u3648 \u3626 \u3619 \u3636 \u3600 \u3605 \u3634 \u3617 \u3607 \u3637 \u3656 \u3607 \u3656 \u3634 \u3609 \u3651 \u3627 \u3657 \u3588 \u3623 \u3634 \u3617 \u3648 \u3627 \u3655 \u3609 \u3609 \u3637 \u3657 \u3604 \u3657 \u3623 \u3618 \u3648 \u3606 \u3636 \u3604 }